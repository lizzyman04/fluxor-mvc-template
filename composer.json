{
    "name": "lizzyman04/fluxor-mvc-template",
    "description": "A complete MVC template with authentication, mailer, uploader, and Cycle ORM - built on Fluxor PHP Framework",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Arlindo Abdul",
            "email": "admin@tudocomlizzyman.com",
            "homepage": "https://lizzyman04.omeu.space",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "lizzyman04/fluxor": "^1.0",
        "cycle/orm": "^2.15",
        "cycle/database": "^2.16",
        "cycle/annotated": "^4.4",
        "cycle/schema-builder": "^2.11",
        "spiral/tokenizer": "^3.16",
        "robmorgan/phinx": "^0.16"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Source\\": "src/",
            "App\\": "app/"
        }
    },
    "scripts": {
        "migrate": "phinx migrate -c db/core/phinx.php",
        "migrate:rollback": "phinx rollback -c db/core/phinx.php",
        "migrate:rollback:all": "phinx rollback -c db/core/phinx.php -t 0",
        "migrate:status": "phinx status -c db/core/phinx.php",
        "seed": "phinx seed:run -c db/core/phinx.php",
        "migration:create": "phinx create -c db/core/phinx.php",
        "dev": "php -S localhost:8000 -t public",
        "prod": "php -S 0.0.0.0:8000 -t public",
        "test": "phpunit"
    },
    "config": {
        "process-timeout": 0
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "version": "1.0.0"
}
