{
    "name": "lizzyman04/composer-mvc-template",
    "description": "A lightweight yet powerful MVC template for PHP projects using Composer.",
    "type": "project",
    "require": {
        "phpmailer/phpmailer": "^6.11",
        "vlucas/phpdotenv": "^5.6",
        "cycle/orm": "^2.11",
        "cycle/database": "^2.15",
        "cycle/annotated": "^4.3",
        "cycle/schema-builder": "^2.11"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Source\\": "src/",
            "Core\\": "core/"
        }
    },
    "scripts": {
        "dev": "php -S localhost:8000 -t public",
        "schema": "php db/schema.php"
    },
    "authors": [
        {
            "name": "lizzyman04",
            "email": "admin@tudocomlizzyman.com"
        }
    ],
    "config": {
        "process-timeout": 0
    }
}